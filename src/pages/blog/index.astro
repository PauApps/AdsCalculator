---
import { getCollection } from 'astro:content';

const lang = 'es';
const isCa = false;
const title = 'Blog de Growth';

// Get posts specifically for Spanish
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.id.startsWith(`${lang}/`) || !post.id.includes('/'));

---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>{title} | GrowthCalc</title>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="../styles/global.css" />
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 p-6">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <a href="/" class="font-bold text-xl">Growth<span class="text-blue-600 italic">Calc</span></a>
        <a href="/" class="text-sm font-medium hover:text-blue-600 transition-colors border px-3 py-1 rounded-lg">Volver a Calculadora</a>
      </div>
    </header>

    <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
      <h1 class="text-4xl font-bold mb-8">Blog de <span class="text-blue-600 italic">Growth</span></h1>
      
      {posts.length === 0 ? (
        <div class="text-gray-500 text-center py-20">No hay posts todavía en español. Próximamente...</div>
      ) : (
        <div class="grid gap-6">
          {posts.map(post => {
             const cleanSlug = post.slug.startsWith('es/') ? post.slug.replace('es/', '') : post.slug;
             return (
               <a href={`/blog/${cleanSlug}`} class="block p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 hover:border-blue-500 transition-all hover:scale-[1.01]">
                 <h2 class="text-2xl font-bold mb-2">{post.data.title}</h2>
                 <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 leading-relaxed">{post.data.description}</p>
                 <span class="text-blue-600 dark:text-blue-400 text-sm font-bold uppercase tracking-wider">Leer más →</span>
               </a>
             )
          })}
        </div>
      )}
    </main>
    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6 mt-20 text-center text-sm text-slate-500">
      <p>© 2026 GrowthCalc. Todos los derechos reservados.</p>
    </footer>
  </body>
</html>
