---
import { getPublishedPosts } from '../../utils/blog';
import Layout from '../../layouts/Layout.astro';

const lang = 'en';
const title = 'Growth Blog | Ads Calculator';
const description = 'Discover the best strategies for Growth Marketing, ROI calculation, and Ads optimization in our blog.';
const keywords = 'blog growth marketing, ads calculator blog, roas strategies, roi calculation';

// Get posts specifically for English
const allPosts = await getPublishedPosts();
const posts = allPosts.filter(post => post.id.startsWith(`${lang}/`));
---

<Layout title={title} description={description} keywords={keywords} lang={lang}>
  <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
    <h1 class="text-4xl font-bold mb-8"><span class="text-blue-600 italic">Growth</span> Blog</h1>
    
    {posts.length === 0 ? (
      <div class="text-gray-500 text-center py-20">No English posts yet. Coming soon...</div>
    ) : (
      <div class="grid gap-6">
        {posts.map(post => {
           const cleanSlug = post.slug.startsWith('en/') ? post.slug.replace('en/', '') : post.slug;
           return (
             <a href={`/blog/${cleanSlug}`} title={`Read article: ${post.data.title}`} class="block p-6 bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-800 hover:border-blue-500 transition-all hover:scale-[1.01]">
               <h2 class="text-2xl font-bold mb-2 text-slate-900 dark:text-white">{post.data.title}</h2>
               <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 leading-relaxed">{post.data.description}</p>
               <span class="text-blue-600 dark:text-blue-400 text-sm font-bold uppercase tracking-wider">Read more →</span>
             </a>
           )
        })}
      </div>
    )}
  </main>
</Layout>
