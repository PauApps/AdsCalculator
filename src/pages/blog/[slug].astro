---
import { getPublishedPosts } from '../../utils/blog';
import Layout from '../../layouts/Layout.astro';
import blogTranslations from '../../utils/blog-translations.json';

export async function getStaticPaths() {
  const blogEntries = await getPublishedPosts();
  // Specifically filter for English entries for the root /blog
  const englishEntries = blogEntries.filter(entry => entry.slug.startsWith('en/'));
  
  return englishEntries.map(entry => {
    // entry.slug includes "en/" prefix
    const slug = entry.slug.replace('en/', '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const lang = 'en';
const currentSlug = Astro.params.slug;

// Find translation mapping
const postKey = Object.keys(blogTranslations).find(key => {
  const t = (blogTranslations as any)[key];
  return t.en === currentSlug;
});

const customAlternates = postKey ? {
  en: `/blog/${(blogTranslations as any)[postKey].en}`,
  es: `/es/blog/${(blogTranslations as any)[postKey].es}`,
  ca: `/ca/blog/${(blogTranslations as any)[postKey].ca}`
} : {
  en: `/blog/${currentSlug}`,
  es: `/es/blog`,
  ca: `/ca/blog`
};
---

<Layout title={`${entry.data.title} | Ads Calculator`} description={entry.data.description} keywords={entry.data.keywords} lang={lang} customAlternates={customAlternates}>
  <main class="flex-grow py-16 px-6">
    <article class="max-w-3xl mx-auto">
      <header class="mb-12 text-center">
         <h1 class="text-4xl md:text-5xl font-extrabold mb-6 text-slate-900 dark:text-white leading-tight">{entry.data.title}</h1>
         <p class="text-xl text-slate-500 dark:text-slate-400 italic max-w-2xl mx-auto">{entry.data.description}</p>
      </header>
      <div class="prose dark:prose-invert mx-auto border-t border-slate-100 dark:border-slate-900 pt-10">
          <Content />
      </div>
      <div class="mt-12 text-center">
        <a href="/blog" title="Back to blog" class="inline-flex items-center gap-2 text-sm font-bold text-blue-600 hover:text-blue-700 transition-colors bg-blue-50 dark:bg-blue-900/30 px-4 py-2 rounded-xl">← Back to Blog</a>
      </div>
    </article>
  </main>
</Layout>
