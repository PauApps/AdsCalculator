---
import Calculator from '../../components/Calculator';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isEs = lang === 'es';
const isCa = lang === 'ca';

const title = isCa 
  ? 'Calculadora ROAS Gratis i ROI Màrqueting | Ads Calculator' 
  : isEs 
    ? 'Calculadora ROAS Gratis y ROI Marketing | Ads Calculator'
    : 'Free ROAS Calculator & ROI Marketing Profit Tool';

const description = isCa 
  ? 'Utilitza la nostra calculadora ROAS gratis per calcular el ROI en màrqueting, punt d\'equilibri i benefici brut. La millor profit ads calculator.' 
  : isEs
    ? 'Usa nuestra calculadora ROAS gratis para calcular el ROI en marketing, punto de equilibrio y beneficio bruto. La mejor profit ads calculator online.'
    : 'Use our free ROAS calculator to calculate ROI marketing, breakeven, and gross profit. The ultimate profit ads calculator with interactive charts.';

const keywords = isCa 
  ? 'calculadora roas gratis, calculadora roi marketing, profit ads calculator, roi ads, roas ads, growth marketing' 
  : isEs
    ? 'calculadora roas gratis, calculadora roi marketing, profit ads calculator, roi ads, roas ads, growth marketing'
    : 'free roas calculator, marketing roi calculator, profit ads calculator, ads profitability, growth marketing, ads roi, ads roas';

const t = {
  heroTitle: isCa 
    ? 'Pren el control de la teva rendibilitat en Ads' 
    : isEs 
      ? 'Toma el control de tu rentabilidad en Ads'
      : 'Take control of your Ads profitability',
  heroSubtitle: isCa 
    ? 'Calcula en segons el ROAS, ROI i breakeven de les teves campanyes de Growth Marketing amb precisió professional.' 
    : isEs
      ? 'Calcula en segundos el ROAS, ROI y breakeven de tus campañas de Growth Marketing con precisión profesional.'
      : 'Calculate ROAS, ROI and breakeven of your Growth Marketing campaigns in seconds with professional precision.',
  cta: isCa 
    ? 'Comença a calcular' 
    : isEs
      ? 'Empieza a calcular'
      : 'Start calculating',
  features: [
    { 
      title: isCa ? 'Càlculs en temps real' : isEs ? 'Cálculos en tiempo real' : 'Real-time calculations', 
      desc: isCa ? 'Veus els resultats a l\'instant.' : isEs ? 'Mira los resultados al instante.' : 'See results instantly.' 
    },
    { 
      title: isCa ? 'Gràfics interactius' : isEs ? 'Gráficos interactivos' : 'Interactive charts', 
      desc: isCa ? 'Visualitza el teu punt d\'equilibri.' : isEs ? 'Visualiza tu punto de equilibrio.' : 'Visualize your breakeven point.' 
    },
    { 
      title: isCa ? 'Privadesa Total' : isEs ? 'Privacidad Total' : 'Total Privacy', 
      desc: isCa ? 'Les teves dades no surten del navegador.' : isEs ? 'Tus datos no salen del navegador.' : 'Your data never leaves your browser.' 
    }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Ads Calculator - ROAS & ROI Business Tool",
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://adsroicalc.com/${lang}`} />
    <link rel="alternate" hreflang="en" href="https://adsroicalc.com/" />
    <link rel="alternate" hreflang="es" href="https://adsroicalc.com/es" />
    <link rel="alternate" hreflang="ca" href="https://adsroicalc.com/ca" />
    <link rel="alternate" hreflang="x-default" href="https://adsroicalc.com/" />
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q73D3FT2VL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-Q73D3FT2VL');
    </script>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8428748101355923" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 dark:text-gray-100 dark:bg-slate-950 hero-gradient">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="glass sticky top-0 z-50 w-full px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
          <div class="font-bold text-2xl tracking-tight flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          Ads <span class="text-blue-600 italic">Calculator</span>
        </div>
        <nav class="flex gap-6 items-center">
          <a href={isCa ? "/ca/blog" : isEs ? "/es/blog" : "/blog"} title={isCa ? "Visitar el blog d'Ads Calculator" : isEs ? "Visitar el blog de Ads Calculator" : "Visit Ads Calculator Blog"} class="text-sm font-medium text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">
            Blog
          </a>
          <div class="flex items-center gap-2 text-sm font-medium border-l border-gray-200 dark:border-gray-800 pl-6">
            <a href="/" title="English version" class="px-2 py-1 rounded-md transition-all text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">EN</a>
            <a href="/es" title="Versión en español" class={`px-2 py-1 rounded-md transition-all ${isEs ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500 hover:text-gray-800 dark:hover:text-gray-200'}`}>ES</a>
            <a href="/ca" title="Versió en català" class={`px-2 py-1 rounded-md transition-all ${isCa ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500 hover:text-gray-800 dark:hover:text-gray-200'}`}>CA</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <!-- HERO SECTION -->
      <section class="pt-20 pb-12 px-6">
        <div class="max-w-4xl mx-auto text-center space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-1000">
          <span class="inline-block px-4 py-1.5 bg-blue-600/10 text-blue-600 rounded-full text-sm font-semibold tracking-wide uppercase">
            {isCa ? 'Eina Gratuïta' : isEs ? 'Herramienta Gratuita' : 'Free Tool'}
          </span>
          <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
            {t.heroTitle}
          </h1>
          <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
            {t.heroSubtitle}
          </p>
          <div class="flex justify-center pt-4">
            <a href="#calculator" title={isCa ? "Anar directament a la calculadora de ROAS i ROI" : isEs ? "Ir directamente a la calculadora de ROAS y ROI" : "Go directly to ROAS and ROI calculator"} class="px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold text-lg shadow-2xl shadow-blue-600/30 hover:scale-105 active:scale-95 transition-all flex items-center gap-2 group">
              {t.cta}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- FEATURES PREVIEW -->
      <section class="py-12 px-6">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
          {t.features.map(f => (
            <div class="p-6 rounded-3xl bg-white/50 dark:bg-white/5 border border-white dark:border-white/10 shadow-sm">
              <h3 class="font-bold text-lg mb-2">{f.title}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- CALCULATOR SECTION -->
      <section id="calculator" class="py-20 px-6 scroll-mt-24">
        <div class="max-w-6xl mx-auto">
          <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden ring-1 ring-black/5">
             <Calculator client:load lang={lang as 'en' | 'es' | 'ca'} />
          </div>
        </div>
      </section>

      <!-- SEO CONTENT -->
      <section class="py-16 px-6">
        <div class="max-w-4xl mx-auto prose dark:prose-invert prose-blue prose-headings:font-bold prose-h2:text-3xl prose-h3:text-xl">
          {isCa ? (
            <>
              <h2>Per què calcular la rendibilitat dels teus Ads és crucial?</h2>
              <p>
                Llançar campanyes de publicitat digital sense mesurar el benefici real és el camí més ràpid per perdre el teu pressupost. En performance i growth marketing, conèixer els teus marges exactes, el teu punt d'equilibri i el teu Retorn de la Inversió (ROI) real no és negociable.
                Aquesta <strong class="font-semibold text-blue-600 dark:text-blue-400">profit ads calculator</strong> t'ajuda a anar més enllà de les mètriques superficials i entendre exactament quants diners fa el teu negoci una vegada deduïts tots els fons.
              </p>

              <h3>Què és el ROAS i com es calcula?</h3>
              <p>
                El <strong>ROAS</strong> (Return on Ad Spend) mesura els ingressos bruts generats per cada euro invertit en publicitat. És la mètrica més habitual dins de plataformes com Facebook Ads o Google Ads.
              </p>
              <p>
                La fórmula és simple: <code>ROAS = Ingressos Totals / Inversió en Ads</code>.
                Encara que un ROAS de 3x o 4x soni genial, només explica la meitat de la història. El ROAS no té en compte el cost del producte, l'enviament ni els impostos, per la qual cosa dependre exclusivament d'ell pot ser perillós per a negocis d'ecommerce i SaaS.
              </p>

              <h3>Com entendre el ROI real (incloent COGS i IVA)</h3>
              <p>
                A diferència del ROAS, el <strong>ROI</strong> (Retorn de la Inversió) et dóna una imatge completa de la teva rendibilitat. Per calcular el teu <em>marketing ROI</em> real, has de restar el <strong>COGS</strong> (Cost dels Béns Venguts) i els impostos (com l'IVA) dels teus ingressos.
              </p>
              <p>
                Un ROAS alt pot encobrir un ROI negatiu si els teus costos de producte i impostos són molt alts. La nostra <strong class="font-semibold text-blue-600 dark:text-blue-400">calculadora ROAS gratis</strong> incorpora automàticament el teu preu de venda, costos unitaris i impostos perquè puguis veure el teu Benefici Net real i el CPA (Cost Per Adquisició).
              </p>

              <h3>Què significa el punt d'equilibri (Breakeven)?</h3>
              <p>
                El teu <strong>ROAS de punt d'equilibri</strong> (Breakeven ROAS) és el multiplicador exacte que necessites assolir en els teus anuncis per cobrir les teves despeses sense perdre diners. Si el teu ROAS real és menor, estàs perdent diners. Si és major, estàs generant pur benefici.
              </p>
              <p>
                En conèixer el teu punt d'equilibri, pots escalar amb confiança les campanyes guanyadores i pausar les perdedores abans que consumeixin el teu pressupost.
              </p>
            </>
          ) : isEs ? (
            <>
              <h2>¿Por qué calcular la rentabilidad de tus Ads es crucial?</h2>
              <p>
                Lanzar campañas de publicidad digital sin medir el beneficio real es el camino más rápido para perder tu presupuesto. En performance y growth marketing, conocer tus márgenes exactos, tu punto de equilibrio y tu Retorno de la Inversión (ROI) real no es negociable.
                Esta <strong class="font-semibold text-blue-600 dark:text-blue-400">profit ads calculator</strong> te ayuda a ir más allá de las métricas superficials y entender exactamente cuánto dinero hace tu negocio una vez deducidos todos los gastos.
              </p>

              <h3>¿Qué es el ROAS y cómo se calcula?</h3>
              <p>
                El <strong>ROAS</strong> (Return on Ad Spend) mide los ingresos brutos generados por cada euro invertido en publicidad. Es la métrica más habitual dentro de plataformas como Facebook Ads o Google Ads.
              </p>
              <p>
                La fórmula es simple: <code>ROAS = Ingresos Totales / Inversión en Ads</code>.
                Aunque un ROAS de 3x o 4x suene genial, solo cuenta la mitad de la historia. El ROAS no tiene en cuenta el coste del producto, el envío ni los impuestos, por lo que depender exclusivamente de él puede ser peligroso para negocios de ecommerce y SaaS.
              </p>

              <h3>Cómo entender el ROI real (incluyendo COGS e IVA)</h3>
              <p>
                A diferencia del ROAS, el <strong>ROI</strong> (Retorno de la Inversión) te da una imagen completa de tu rentabilidad. Para calcular tu <em>marketing ROI</em> real, debes restar el <strong>COGS</strong> (Coste de los Bienes Vendidos) y los impuestos (como el IVA) de tus ingresos.
              </p>
              <p>
                Un ROAS alto puede encubrir un ROI negativo si tus costes de producto e impuestos son muy altos. Nuestra <strong class="font-semibold text-blue-600 dark:text-blue-400">calculadora ROAS gratis</strong> incorpora automáticamente tu precio de venta, costes unitarios e impuestos para que puedas ver tu Beneficio Neto real y el CPA (Coste Por Adquisición).
              </p>

              <h3>¿Qué significa el punto de equilibrio (Breakeven)?</h3>
              <p>
                Tu <strong>ROAS de punto de equilibrio</strong> (Breakeven ROAS) es el multiplicador exacto que necesitas alcanzar en tus anuncios para cubrir tus gastos sin perder dinero. Si tu ROAS real es menor, estás perdiendo dinero. Si es mayor, estás generando puro beneficio.
              </p>
              <p>
                Al conocer tu punto de equilibrio, puedes escalar con confianza las campañas ganadoras y pausar las perdedores antes de que consuman tu presupuesto.
              </p>
            </>
          ) : (
            <>
              <h2>Why calculating your Ads profitability is crucial?</h2>
              <p>
                Running digital advertising campaigns without tracking your actual profit is a fast track to burning your budget. In performance and growth marketing, knowing your exact margins, your breakeven point, and your real Return on Investment (ROI) is non-negotiable. 
                This <strong class="font-semibold text-blue-600 dark:text-blue-400">profit ads calculator</strong> helps you move beyond vanity metrics and understand exactly how much money your business is making after all costs are deducted.
              </p>

              <h3>What is ROAS and how is it calculated?</h3>
              <p>
                <strong>ROAS</strong> (Return on Ad Spend) measures the gross revenue generated for every dollar spent on advertising. It's the most common metric used inside ad platforms like Facebook Ads or Google Ads. 
              </p>
              <p>
                The formula is simple: <code>ROAS = Total Revenue / Ad Spend</code>. 
                While a 3x or 4x ROAS might sound great, it only tells half the story. ROAS does not account for product costs, shipping, or taxes, which is why relying solely on it can be dangerous for ecommerce and SaaS businesses.
              </p>

              <h3>Understanding real ROI (including COGS and VAT)</h3>
              <p>
                Unlike ROAS, <strong>ROI</strong> (Return on Investment) gives you a complete picture of your profitability. To calculate your real <em>marketing ROI</em>, you must subtract the <strong>COGS</strong> (Cost of Goods Sold) and taxes (like VAT or sales tax) from your revenue.
              </p>
              <p>
                A high ROAS can actually mask a negative ROI if your product costs and taxes are too high. Our <strong class="font-semibold text-blue-600 dark:text-blue-400">free ROAS calculator</strong> automatically factors in your sale price, unit costs, and tax rate so you can see your true Net Profit and CPA (Cost Per Acquisition).
              </p>

              <h3>What does the Breakeven point mean?</h3>
              <p>
                Your <strong>Breakeven ROAS</strong> is the exact multiplier you need to hit on your ads just to cover all your expenses without losing money. If your actual ROAS is lower than your Breakeven ROAS, your ad campaigns are bleeding money. If it's higher, you are generating pure profit.
              </p>
              <p>
                By knowing your breakeven point, you can confidently scale your winning campaigns and kill the losing ones before they drain your bank account.
              </p>
            </>
          )}
        </div>
      </section>
    </main>

    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="text-center md:text-left">
           <div class="font-bold text-xl mb-2 flex items-center justify-center md:justify-start gap-2">
              <div class="w-6 h-6 bg-blue-600 rounded-md flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              Ads <span class="text-blue-600 italic">Calculator</span>
           </div>
           <p class="text-sm text-slate-500 dark:text-slate-400">© 2026 Ads Calculator. {isCa ? 'Tots els drets reservats.' : isEs ? 'Todos los derechos reservados.' : 'All rights reserved.'}</p>
           <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Contact: <a href="mailto:info@adsroicalc.com" class="hover:text-blue-600 transition-colors">info@adsroicalc.com</a></p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-400">
           <a href={isCa ? "/ca/blog" : isEs ? "/es/blog" : "/blog"} title={isCa ? "Veure tots els articles del blog" : isEs ? "Ver todos los artículos del blog" : "See all blog posts"} class="hover:text-blue-600 transition-colors">Blog</a>
           <a href="/privacy" title={isCa ? "Política de Privacitat" : isEs ? "Política de Privacidad" : "Privacy Policy"} class="hover:text-blue-600 transition-colors">{isCa ? 'Privadesa' : isEs ? 'Privacidad' : 'Privacy'}</a>
           <a href="/legal" title={isCa ? "Avís Legal" : isEs ? "Aviso Legal" : "Legal Notice"} class="hover:text-blue-600 transition-colors">Legal</a>
           <a href="/cookies" title={isCa ? "Política de Cookies" : isEs ? "Política de Cookies" : "Cookie Policy"} class="hover:text-blue-600 transition-colors">Cookies</a>
        </div>
      </div>
  </body>
</html>

