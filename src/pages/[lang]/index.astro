---
import Calculator from '../../components/Calculator';
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isCa = lang === 'ca';
const title = isCa ? 'Ads Calculator | Calculadora ROAS & ROI Professional' : 'Ads Calculator | Calculadora ROAS & ROI Profesional';
const description = isCa ? 'Calcula ROAS, ROI i breakeven dels teus Ads. Mesura el benefici real amb gràfics interactius.' : 'Calcula ROAS, ROI y breakeven de tus Ads. Mide el beneficio real con gráficos interactivos.';
const keywords = isCa ? 'calculadora ads, calculadora roas, calculadora roi, rendibilitat ads, growth marketing, roi ads, roas ads' : 'calculadora ads, calculadora roas, calculadora roi, rentabilidad ads, growth marketing, roi ads, roas ads';

const t = {
  heroTitle: isCa ? 'Pren el control de la teva rendibilitat en Ads' : 'Toma el control de tu rentabilidad en Ads',
  heroSubtitle: isCa ? 'Calcula en segons el ROAS, ROI i breakeven de les teves campanyes de Growth Marketing amb precisió professional.' : 'Calcula en segundos el ROAS, ROI y breakeven de tus campañas de Growth Marketing con precisión profesional.',
  cta: isCa ? 'Comença a calcular' : 'Empieza a calcular',
  features: [
    { title: isCa ? 'Càlculs en temps real' : 'Cálculos en tiempo real', desc: isCa ? 'Veus els resultats a l\'instant.' : 'Mira los resultados al instante.' },
    { title: isCa ? 'Gràfics interactius' : 'Gráficos interactivos', desc: isCa ? 'Visualitza el teu punt d\'equilibri.' : 'Visualiza tu punto de equilibrio.' },
    { title: isCa ? 'Privadesa Total' : 'Privacidad Total', desc: isCa ? 'Les teves dades no surten del navegador.' : 'Tus datos no salen del navegador.' }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Ads Calculator - ROAS & ROI Business Tool",
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://adscalculator.app/${lang}`} />
    <link rel="alternate" hreflang="es" href="https://adscalculator.app/" />
    <link rel="alternate" hreflang="ca" href="https://adscalculator.app/ca" />
    <link rel="alternate" hreflang="x-default" href="https://adscalculator.app/" />
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 dark:text-gray-100 dark:bg-slate-950 hero-gradient">
    <header class="glass sticky top-0 z-50 w-full px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
          <div class="font-bold text-2xl tracking-tight flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          Ads <span class="text-blue-600 italic">Calculator</span>
        </div>
        <nav class="flex gap-6 items-center">
          <a href={isCa ? "/ca/blog" : "/blog"} class="text-sm font-medium text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">
            Blog
          </a>
          <div class="flex items-center gap-2 text-sm font-medium border-l border-gray-200 dark:border-gray-800 pl-6">
            <a href="/" class="px-2 py-1 rounded-md transition-all text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">ES</a>
            <a href="/ca" class={`px-2 py-1 rounded-md transition-all ${isCa ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500 hover:text-gray-800 dark:hover:text-gray-200'}`}>CA</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <!-- HERO SECTION -->
      <section class="pt-20 pb-12 px-6">
        <div class="max-w-4xl mx-auto text-center space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-1000">
          <span class="inline-block px-4 py-1.5 bg-blue-600/10 text-blue-600 rounded-full text-sm font-semibold tracking-wide uppercase">
            {isCa ? 'Eina Gratuïta' : 'Herramienta Gratuita'}
          </span>
          <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
            {t.heroTitle}
          </h1>
          <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
            {t.heroSubtitle}
          </p>
          <div class="flex justify-center pt-4">
            <a href="#calculator" class="px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold text-lg shadow-2xl shadow-blue-600/30 hover:scale-105 active:scale-95 transition-all flex items-center gap-2 group">
              {t.cta}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- FEATURES PREVIEW -->
      <section class="py-12 px-6">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
          {t.features.map(f => (
            <div class="p-6 rounded-3xl bg-white/50 dark:bg-white/5 border border-white dark:border-white/10 shadow-sm">
              <h3 class="font-bold text-lg mb-2">{f.title}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- CALCULATOR SECTION -->
      <section id="calculator" class="py-20 px-6 scroll-mt-24">
        <div class="max-w-6xl mx-auto">
          <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden ring-1 ring-black/5">
             <Calculator client:load lang={lang as 'es' | 'ca'} />
          </div>
        </div>
      </section>
    </main>

    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div>
           <div class="font-bold text-xl mb-2 flex items-center gap-2">
              <div class="w-6 h-6 bg-blue-600 rounded-md flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              Ads <span class="text-blue-600 italic">Calculator</span>
           </div>
           <p class="text-sm text-slate-500 dark:text-slate-400">© 2026 Ads Calculator. {isCa ? 'Tots els drets reservats.' : 'Todos los derechos reservados.'}</p>
        </div>
        <div class="flex gap-8 text-sm font-medium text-slate-600 dark:text-slate-400">
           <a href="#" class="hover:text-blue-600 transition-colors">Twitter</a>
           <a href="#" class="hover:text-blue-600 transition-colors">LinkedIn</a>
           <a href={isCa ? "/ca/blog" : "/blog"} class="hover:text-blue-600 transition-colors">Blog</a>
        </div>
      </div>
    </footer>
  </body>
</html>

