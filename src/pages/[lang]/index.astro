---
import Calculator from '../../components/Calculator';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;

const isCa = lang === 'ca';
const title = isCa ? 'Calculadora de ROAS & ROI - Eina de Growth Marketing' : 'Calculadora de ROAS & ROI - Herramienta de Growth Marketing';
const description = isCa ? 'Calcula el ROAS, ROI, CPA i marge de les teves campanyes publicitàries.' : 'Calcula el ROAS, ROI, CPA y margen de tus campañas publicitarias.';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "ROAS & ROI Business Calculator",
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
      
      :root {
        --primary: #2563eb;
        --primary-foreground: #ffffff;
      }

      .dark {
        --primary: #3b82f6;
        --primary-foreground: #ffffff;
      }

      body {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
      }
      .dark body {
        background-color: #0f172a;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 dark:text-gray-100">
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 sticky top-0 z-10 w-full px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <div class="font-bold text-xl tracking-tight">Growth<span class="text-primary">Calc</span></div>
        <nav class="flex gap-4 items-center">
          <a href={`/${lang}/blog`} class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors">
            Blog
          </a>
          <div class="flex items-center gap-2 text-sm font-medium ml-4">
            <a href="/es" class={`px-2 py-1 rounded ${!isCa ? 'bg-gray-100 dark:bg-gray-800 text-primary' : 'text-gray-500'}`}>ES</a>
            <span class="text-gray-300 dark:text-gray-700">|</span>
            <a href="/ca" class={`px-2 py-1 rounded ${isCa ? 'bg-gray-100 dark:bg-gray-800 text-primary' : 'text-gray-500'}`}>CA</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow py-8 bg-gray-50 dark:bg-gray-900 min-h-[calc(100vh-140px)]">
      <Calculator client:load lang={lang as 'es' | 'ca'} />
    </main>

    <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 py-8 text-center text-gray-500 dark:text-gray-400 text-sm">
      <p>© 2026 GrowthCalc. {isCa ? 'Tots els drets reservats.' : 'Todos los derechos reservados.'}</p>
      <div class="mt-2 text-xs opacity-75">
        Diseñado con Shadcn/ui vibes & Tailwind CSS.
      </div>
    </footer>
  </body>
</html>
