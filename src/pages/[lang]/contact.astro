---
import '../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isEs = lang === 'es';
const isCa = lang === 'ca';

const title = isCa 
  ? 'Contacte | Ads Calculator' 
  : 'Contacto | Ads Calculator';

const description = isCa 
  ? 'Posa\'t en contacte amb l\'equip d\'Ads Calculator. Escriu-nos a info@adsroicalc.com per a preguntes, comentaris o consultes comercials.' 
  : 'Ponte en contacto con el equipo de Ads Calculator. Escríbenos a info@adsroicalc.com para preguntas, sugerencias o consultas comerciales.';

const keywords = isCa
  ? 'contacte, correu ads calculator, suport, info@adsroicalc.com'
  : 'contacto, correo ads calculator, soporte, info@adsroicalc.com';

const textHero = isCa
  ? 'Tens alguna pregunta, suggeriment per a noves funcionalitats de càlcul o consultes comercials? Ens encantaria escoltar-te. Posa\'t en contacte directament amb nosaltres.'
  : '¿Tienes alguna pregunta, sugerencia para nuevas funcionalidades de cálculo o consultas comerciales? Nos encantaría escucharte. Ponte en contacto directamente con nosotros.';

const textBadge = isCa
  ? 'Suport per Correu Directe'
  : 'Soporte por Correo Directo';

const btnCopy = isCa ? 'Copiar Correu' : 'Copiar Correo';
const btnSend = isCa ? 'Enviar Missatge' : 'Enviar Mensaje';
const textReply = isCa
  ? 'Normalment responem a totes les consultes en un termini de 24–48 hores laborables.'
  : 'Normalmente respondemos a todas las consultas en un plazo de 24–48 horas laborables.';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://adsroicalc.com/${lang}/contact`} />
    <link rel="alternate" hreflang="en" href="https://adsroicalc.com/contact" />
    <link rel="alternate" hreflang="es" href="https://adsroicalc.com/es/contact" />
    <link rel="alternate" hreflang="ca" href="https://adsroicalc.com/ca/contact" />
    <link rel="alternate" hreflang="x-default" href="https://adsroicalc.com/contact" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q73D3FT2VL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q73D3FT2VL');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8428748101355923" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 dark:text-gray-100 dark:bg-slate-950 hero-gradient">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    
    <header class="glass sticky top-0 z-50 w-full px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href={isCa ? "/ca" : "/es"} class="font-bold text-2xl tracking-tight flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          Ads <span class="text-blue-600 italic">Calculator</span>
        </a>
        <nav class="flex gap-3 md:gap-6 items-center">
          <a href={isCa ? "/ca/blog" : "/es/blog"} class="text-sm font-medium text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">Blog</a>
          <div class="flex items-center gap-2 text-sm font-medium border-l border-gray-200 dark:border-gray-800 pl-3 md:pl-6">
            <a href="/contact" title="English version" class="px-2 py-1 rounded-md text-gray-500 hover:text-gray-800 dark:hover:text-gray-200 transition-colors">EN</a>
            <span class={`px-2 py-1 rounded-md ${isEs ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500'}`}>ES</span>
            <span class={`px-2 py-1 rounded-md ${isCa ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500'}`}>CA</span>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow py-12 sm:py-24 px-4 sm:px-6 flex items-center justify-center">
      <div class="max-w-xl w-full bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-[2rem] shadow-2xl border border-white/20 dark:border-white/5 p-8 sm:p-12 text-center animate-in fade-in slide-in-from-bottom-4 duration-1000">
        <!-- Icon Banner -->
        <div class="w-16 h-16 bg-blue-100 dark:bg-blue-900/40 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg shadow-blue-500/10 dark:shadow-none">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
        </div>

        <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
          {isCa ? 'Contacte' : 'Contacto'}
        </h1>
        <p class="text-slate-600 dark:text-slate-400 text-base mb-8 leading-relaxed">
          {textHero}
        </p>

        <!-- Professional Copyable Email Card -->
        <div class="bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl p-6 mb-8 relative group">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500 block mb-2">{textBadge}</span>
          <a href="mailto:info@adsroicalc.com" class="text-xl sm:text-2xl font-bold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 break-all select-all transition-colors">
            info@adsroicalc.com
          </a>
          
          <div class="flex justify-center gap-3 mt-4">
            <button 
              id="copy-btn" 
              class="px-4 py-2 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 text-sm font-semibold rounded-xl text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-850 hover:scale-105 active:scale-95 transition-all shadow-sm flex items-center gap-2"
            >
              <svg id="copy-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg>
              <span id="copy-text">{btnCopy}</span>
            </button>
            <a 
              href="mailto:info@adsroicalc.com" 
              class="px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 hover:scale-105 active:scale-95 transition-all shadow-md shadow-blue-600/20 flex items-center gap-2"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
              {btnSend}
            </a>
          </div>
        </div>

        <p class="text-slate-400 dark:text-slate-500 text-xs">
          {textReply}
        </p>
      </div>
    </main>

    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="text-center md:text-left">
           <div class="font-bold text-xl mb-2 flex items-center justify-center md:justify-start gap-2">
              <div class="w-6 h-6 bg-blue-600 rounded-md flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              Ads <span class="text-blue-600 italic">Calculator</span>
           </div>
           <p class="text-sm text-slate-500 dark:text-slate-400">© 2026 Ads Calculator. {isCa ? 'Tots els drets reservats.' : 'Todos los derechos reservados.'}</p>
           <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Contact: <a href="mailto:info@adsroicalc.com" class="hover:text-blue-600 transition-colors">info@adsroicalc.com</a></p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-400">
           <a href={isCa ? "/ca/blog" : "/es/blog"} title={isCa ? "Veure tots els articles del blog" : "Ver todos los artículos del blog"} class="hover:text-blue-600 transition-colors">Blog</a>
           <a href={isCa ? "/ca/privacy" : "/es/privacy"} class="hover:text-blue-600 transition-colors">{isCa ? 'Privadesa' : 'Privacidad'}</a>
           <a href={isCa ? "/ca/legal" : "/es/legal"} class="hover:text-blue-600 transition-colors">Legal</a>
           <a href={isCa ? "/ca/cookies" : "/es/cookies"} class="hover:text-blue-600 transition-colors">Cookies</a>
           <a href={isCa ? "/ca/contact" : "/es/contact"} class="hover:text-blue-600 transition-colors">{isCa ? 'Contacte' : 'Contacto'}</a>
        </div>
      </div>
    </footer>

    <!-- Copy to Clipboard Script -->
    <script is:inline define:vars={{ isCa }}>
      const copyBtn = document.getElementById('copy-btn');
      const copyText = document.getElementById('copy-text');
      const copyIcon = document.getElementById('copy-icon');

      if (copyBtn) {
        copyBtn.addEventListener('click', () => {
          const email = "info@adsroicalc.com";
          navigator.clipboard.writeText(email).then(() => {
            const successText = isCa ? "Copiat!" : "¡Copiado!";
            const originalText = isCa ? "Copiar Correu" : "Copiar Correo";

            copyText.textContent = successText;
            copyBtn.classList.add('bg-green-50', 'dark:bg-green-950/20', 'border-green-300', 'dark:border-green-800', 'text-green-600', 'dark:text-green-400');
            copyIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>`;
            
            setTimeout(() => {
              copyText.textContent = originalText;
              copyBtn.classList.remove('bg-green-50', 'dark:bg-green-950/20', 'border-green-300', 'dark:border-green-800', 'text-green-600', 'dark:text-green-400');
              copyIcon.innerHTML = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path>`;
            }, 2000);
          }).catch(err => {
            console.error('Failed to copy text: ', err);
          });
        });
      }
    </script>
  </body>
</html>
