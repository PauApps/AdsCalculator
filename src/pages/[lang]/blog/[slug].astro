---
import { getCollection } from 'astro:content';
import '../../../styles/global.css';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  // Specifically filter for Catalan entries for the /ca/blog
  const catalanEntries = blogEntries.filter(entry => entry.slug.startsWith('ca/'));
  
  return catalanEntries.map(entry => {
    // entry.slug includes "ca/" prefix
    const slug = entry.slug.replace('ca/', '');
    const lang = 'ca';
    return {
      params: { lang, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { lang } = Astro.params;
const { Content } = await entry.render();

const isCa = lang === 'ca';
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{entry.data.title} | Ads Calculator</title>
    <meta name="viewport" content="width=device-width" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q73D3FT2VL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-Q73D3FT2VL');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 p-6">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <a href={`/${lang}`} class="font-bold text-xl">Ads <span class="text-blue-600 italic">Calculator</span></a>
        <a href={`/${lang}/blog`} class="text-sm font-medium hover:text-blue-600 transition-colors">← {isCa ? 'Tornar al Blog' : 'Volver al Blog'}</a>
      </div>
    </header>

    <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
      <article class="prose dark:prose-invert mx-auto">
        <h1 class="text-4xl font-extrabold mb-4">{entry.data.title}</h1>
        <p class="text-gray-500 mb-8">{entry.data.description}</p>
        <div class="border-t border-gray-200 dark:border-gray-800 pt-8">
            <Content />
        </div>
      </article>
    </main>

    <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-800 py-8 text-center text-gray-500 dark:text-gray-400 text-sm">
        <p>© 2026 Ads Calculator. {isCa ? 'Tots els drets reservats.' : 'Todos los derechos reservados.'}</p>
    </footer>
  </body>
</html>
