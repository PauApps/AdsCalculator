---
import { getCollection } from 'astro:content';
import '../../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isCa = lang === 'ca';
const title = isCa ? 'Blog de Growth' : 'Blog de Growth';

// Simulate getting collection, filtering by language if needed (we'll just list them)
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.id.startsWith(`${lang}/`) || !post.id.includes('/'));

---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>{title} | Ads Calculator</title>
    <meta name="viewport" content="width=device-width" />
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 p-6">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <a href={`/${lang}`} class="font-bold text-xl">Ads <span class="text-blue-600 italic">Calculator</span></a>
        <a href={`/${lang}`} class="text-sm font-medium hover:text-blue-600 transition-colors">{isCa ? 'Tornar a la Calculadora' : 'Volver a Calculadora'}</a>
      </div>
    </header>

    <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
      <h1 class="text-3xl font-bold mb-8">{title}</h1>
      
      {posts.length === 0 ? (
        <div class="text-gray-500">{isCa ? 'No hi ha posts encara. Pròximament...' : 'No hay posts todavía. Próximamente...'}</div>
      ) : (
        <div class="grid gap-6">
          {posts.map(post => (
            <a href={`/${lang}/blog/${post.slug}`} class="block p-6 bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700 hover:border-blue-500 transition-colors">
              <h2 class="text-xl font-semibold mb-2">{post.data.title}</h2>
              <p class="text-gray-600 dark:text-gray-400 text-sm mb-4">{post.data.description}</p>
              <span class="text-blue-600 dark:text-blue-400 text-sm font-medium">{isCa ? 'Llegir més →' : 'Leer más →'}</span>
            </a>
          ))}
        </div>
      )}
    </main>
  </body>
</html>
