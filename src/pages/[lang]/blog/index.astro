---
import { getCollection } from 'astro:content';
import '../../../styles/global.css';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isEs = lang === 'es';
const isCa = lang === 'ca';
const title = isCa ? 'Blog de Growth' : isEs ? 'Blog de Growth' : 'Growth Blog';

// Get posts specifically for the current language
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.id.startsWith(`${lang}/`));

---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Ads Calculator</title>
    <meta name="description" content={isCa ? "Descobreix les millors estratègies de Growth Marketing, càlcul de ROI i optimització d'Ads al nostre blog." : "Descubre las mejores estrategias de Growth Marketing, cálculo de ROI y optimización de Ads en nuestro blog."} />
    <meta name="keywords" content={isCa ? "blog growth marketing, ads calculator blog, roas català, càlcul roi" : "blog growth marketing, ads calculator blog, roas estrategias, calculo roi"} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={`https://adsroicalc.com/${lang}/blog`} />
    
    <link rel="alternate" hreflang="en" href="https://adsroicalc.com/blog" />
    <link rel="alternate" hreflang="es" href="https://adsroicalc.com/es/blog" />
    <link rel="alternate" hreflang="ca" href="https://adsroicalc.com/ca/blog" />
    <link rel="alternate" hreflang="x-default" href="https://adsroicalc.com/blog" />

    <meta name="viewport" content="width=device-width" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q73D3FT2VL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-Q73D3FT2VL');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8428748101355923" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-800 p-6">
      <div class="max-w-4xl mx-auto flex justify-between items-center">
        <a href={`/${lang}`} title={isCa ? "Tornar a la pàgina principal" : "Volver a la página principal"} class="font-bold text-xl">Ads <span class="text-blue-600 italic">Calculator</span></a>
        <div class="flex gap-4 items-center">
          <div class="flex items-center gap-2 text-sm font-medium pr-4 border-r border-gray-200 dark:border-gray-800">
             <a href="/blog" title="English blog" class="px-2 py-1 rounded-md transition-all text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">EN</a>
             <a href="/es/blog" title="Blog en español" class={`px-2 py-1 rounded-md transition-all ${isEs ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500 hover:text-gray-800 dark:hover:text-gray-200'}`}>ES</a>
             <a href="/ca/blog" title="Blog en català" class={`px-2 py-1 rounded-md transition-all ${isCa ? 'bg-blue-600 text-white shadow-lg shadow-blue-600/25' : 'text-gray-500 hover:text-gray-800 dark:hover:text-gray-200'}`}>CA</a>
          </div>
          <a href={`/${lang}`} title={isCa ? "Tornar a la calculadora" : "Volver a la calculadora"} class="text-sm font-medium hover:text-blue-600 transition-colors border px-3 py-1 rounded-lg">{isCa ? 'Tornar' : 'Volver'}</a>
        </div>
      </div>
    </header>

    <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
      <h1 class="text-4xl font-bold mb-8">{isCa ? 'Blog de ' : 'Blog de '}<span class="text-blue-600 italic">Growth</span></h1>
      
      {posts.length === 0 ? (
        <div class="text-gray-500 text-center py-20">{isCa ? 'No hi ha posts encara en català. Pròximament...' : 'No hay posts todavía en español. Próximamente...'}</div>
      ) : (
        <div class="grid gap-6">
          {posts.map(post => {
             const cleanSlug = post.slug.split('/').pop();
             return (
               <a href={`/${lang}/blog/${cleanSlug}`} title={isCa ? `Llegir l'article: ${post.data.title}` : `Leer el artículo: ${post.data.title}`} class="block p-6 bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 hover:border-blue-500 transition-all hover:scale-[1.01]">
                 <h2 class="text-2xl font-bold mb-2">{post.data.title}</h2>
                 <p class="text-gray-600 dark:text-gray-400 text-sm mb-4 leading-relaxed">{post.data.description}</p>
                 <span class="text-blue-600 dark:text-blue-400 text-sm font-bold uppercase tracking-wider">{isCa ? 'Llegir més →' : 'Leer más →'}</span>
               </a>
             )
          })}
        </div>
      )}
    </main>
    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6 mt-20 text-center text-sm text-slate-500">
      <p>© 2026 Ads Calculator. {isCa ? 'Tots els drets reservats.' : 'Todos los derechos reservados.'}</p>
    </footer>
  </body>
</html>
