---
import { getPublishedPosts } from '../../../utils/blog';
import Layout from '../../../layouts/Layout.astro';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'ca' } },
  ];
}

const { lang } = Astro.params;
const isEs = lang === 'es';
const isCa = lang === 'ca';
const title = isCa ? 'Blog de Growth | Ads Calculator' : isEs ? 'Blog de Growth | Ads Calculator' : 'Growth Blog | Ads Calculator';
const description = isCa ? "Descobreix les millors estratègies de Growth Marketing, càlcul de ROI i optimització d'Ads al nostre blog." : "Descubre las mejores estrategias de Growth Marketing, cálculo de ROI y optimización de Ads en nuestro blog.";
const keywords = isCa ? "blog growth marketing, ads calculator blog, roas català, càlcul roi" : "blog growth marketing, ads calculator blog, roas estrategias, calculo roi";

// Get posts specifically for the current language
const allPosts = await getPublishedPosts();
const posts = allPosts.filter(post => post.id.startsWith(`${lang}/`));
---

<Layout title={title} description={description} keywords={keywords} lang={lang as 'es' | 'ca'}>
  <main class="flex-grow py-12 max-w-4xl mx-auto w-full px-6">
    <h1 class="text-4xl font-bold mb-8">{isCa ? 'Blog de ' : 'Blog de '}<span class="text-blue-600 italic">Growth</span></h1>
    
    {posts.length === 0 ? (
      <div class="text-gray-500 text-center py-20">{isCa ? 'No hi ha posts encara en català. Pròximament...' : 'No hay posts todavía en español. Próximamente...'}</div>
    ) : (
      <div class="grid gap-6">
        {posts.map(post => {
           const cleanSlug = post.slug.split('/').pop();
           return (
             <a href={`/${lang}/blog/${cleanSlug}`} title={isCa ? `Llegir l'article: ${post.data.title}` : `Leer el artículo: ${post.data.title}`} class="block p-6 bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-800 hover:border-blue-500 transition-all hover:scale-[1.01]">
               <h2 class="text-2xl font-bold mb-2 text-slate-900 dark:text-white">{post.data.title}</h2>
               <p class="text-slate-600 dark:text-slate-400 text-sm mb-4 leading-relaxed">{post.data.description}</p>
               <span class="text-blue-600 dark:text-blue-400 text-sm font-bold uppercase tracking-wider">{isCa ? 'Llegir més →' : 'Leer más →'}</span>
             </a>
           )
        })}
      </div>
    )}
  </main>
</Layout>
