---
import Calculator from '../components/Calculator';
import Layout from '../layouts/Layout.astro';

const lang = 'en';
const title = 'Free ROAS Calculator & ROI Marketing Profit Tool';
const description = 'Use our free ROAS calculator to calculate ROI marketing, breakeven, and gross profit. The ultimate profit ads calculator with interactive charts.';
const keywords = 'free roas calculator, marketing roi calculator, profit ads calculator, ads profitability, growth marketing, ads roi, ads roas';

const t = {
  heroTitle: 'Take control of your Ads profitability',
  heroSubtitle: 'Calculate ROAS, ROI and breakeven of your Growth Marketing campaigns in seconds with professional precision.',
  cta: 'Start calculating',
  features: [
    { title: 'Real-time calculations', desc: 'See results instantly.' },
    { title: 'Interactive charts', desc: 'Visualize your breakeven point.' },
    { title: 'Total Privacy', desc: 'Your data never leaves your browser.' }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Ads Calculator - ROAS & ROI Business Tool",
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<Layout title={title} description={description} keywords={keywords} lang={lang}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <main class="flex-grow">
    <!-- HERO SECTION -->
    <section class="pt-16 sm:pt-20 pb-12 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto text-center space-y-6 sm:space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-1000">
        <span class="inline-block px-4 py-1.5 bg-blue-600/10 text-blue-600 rounded-full text-sm font-semibold tracking-wide uppercase">
          Free Tool
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
          {t.heroTitle}
        </h1>
        <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
          {t.heroSubtitle}
        </p>
        <div class="flex justify-center pt-4">
          <a href="#calculator" title="Go directly to ROAS and ROI calculator" class="px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold text-lg shadow-2xl shadow-blue-600/30 hover:scale-105 active:scale-95 transition-all flex items-center gap-2 group">
            {t.cta}
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- FEATURES PREVIEW -->
    <section class="py-12 px-6">
      <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
        {t.features.map(f => (
          <div class="p-6 rounded-3xl bg-white/50 dark:bg-white/5 border border-white dark:border-white/10 shadow-sm">
            <h3 class="font-bold text-lg mb-2">{f.title}</h3>
            <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CALCULATOR SECTION -->
    <section id="calculator" class="py-12 sm:py-20 px-2 sm:px-6 scroll-mt-24">
      <div class="max-w-6xl mx-auto">
        <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-[2rem] sm:rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden ring-1 ring-black/5">
           <Calculator client:load lang={lang} />
        </div>
      </div>
    </section>

    <!-- SEO CONTENT -->
    <section class="py-16 px-6">
      <div class="max-w-4xl mx-auto prose dark:prose-invert prose-blue prose-headings:font-bold prose-h2:text-3xl prose-h3:text-xl">
        <h2>Why calculating your Ads profitability is crucial?</h2>
        <p>
          Running digital advertising campaigns without tracking your actual profit is a fast track to burning your budget. In performance and growth marketing, knowing your exact margins, your breakeven point, and your real Return on Investment (ROI) is non-negotiable. 
          This <strong class="font-semibold text-blue-600 dark:text-blue-400">profit ads calculator</strong> helps you move beyond vanity metrics and understand exactly how much money your business is making after all costs are deducted.
        </p>

        <h3>What is ROAS and how is it calculated?</h3>
        <p>
          <strong>ROAS</strong> (Return on Ad Spend) measures the gross revenue generated for every dollar spent on advertising. It's the most common metric used inside ad platforms like Facebook Ads or Google Ads. 
        </p>
        <p>
          The formula is simple: <code>ROAS = Total Revenue / Ad Spend</code>. 
          While a 3x or 4x ROAS might sound great, it only tells half the story. ROAS does not account for product costs, shipping, or taxes, which is why relying solely on it can be dangerous for ecommerce and SaaS businesses.
        </p>

        <h3>Understanding real ROI (including COGS and VAT)</h3>
        <p>
          Unlike ROAS, <strong>ROI</strong> (Return on Investment) gives you a complete picture of your profitability. To calculate your real <em>marketing ROI</em>, you must subtract the <strong>COGS</strong> (Cost of Goods Sold) and taxes (like VAT or sales tax) from your revenue.
        </p>
        <p>
          A high ROAS can actually mask a negative ROI if your product costs and taxes are too high. Our <strong class="font-semibold text-blue-600 dark:text-blue-400">free ROAS calculator</strong> automatically factors in your sale price, unit costs, and tax rate so you can see your true Net Profit and CPA (Cost Per Acquisition).
        </p>

        <h3>What does the Breakeven point mean?</h3>
        <p>
          Your <strong>Breakeven ROAS</strong> is the exact multiplier you need to hit on your ads just to cover all your expenses without losing money. If your actual ROAS is lower than your Breakeven ROAS, your ad campaigns are bleeding money. If it's higher, you are generating pure profit.
        </p>
        <p>
          By knowing your breakeven point, you can confidently scale your winning campaigns and kill the losing ones before they drain your bank account.
        </p>
      </div>
    </section>
  </main>
</Layout>
