---
import Calculator from '../components/Calculator';
import '../styles/global.css';

const lang = 'en';
const title = 'Free ROAS Calculator & ROI Marketing Profit Tool';
const description = 'Use our free ROAS calculator to calculate ROI marketing, breakeven, and gross profit. The ultimate profit ads calculator with interactive charts.';
const keywords = 'free roas calculator, marketing roi calculator, profit ads calculator, ads profitability, growth marketing, ads roi, ads roas';

const t = {
  heroTitle: 'Take control of your Ads profitability',
  heroSubtitle: 'Calculate ROAS, ROI and breakeven of your Growth Marketing campaigns in seconds with professional precision.',
  cta: 'Start calculating',
  features: [
    { title: 'Real-time calculations', desc: 'See results instantly.' },
    { title: 'Interactive charts', desc: 'Visualize your breakeven point.' },
    { title: 'Total Privacy', desc: 'Your data never leaves your browser.' }
  ]
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Ads Calculator - ROAS & ROI Business Tool",
  "operatingSystem": "All",
  "applicationCategory": "BusinessApplication",
  "description": description,
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "EUR"
  }
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://adsroicalc.com/" />
    <link rel="alternate" hreflang="en" href="https://adsroicalc.com/" />
    <link rel="alternate" hreflang="es" href="https://adsroicalc.com/es" />
    <link rel="alternate" hreflang="ca" href="https://adsroicalc.com/ca" />
    <link rel="alternate" hreflang="x-default" href="https://adsroicalc.com/" />
    
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q73D3FT2VL"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-Q73D3FT2VL');
    </script>

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MMWNVNNP');</script>
    <!-- End Google Tag Manager -->

    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8428748101355923" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col text-gray-900 dark:text-gray-100 dark:bg-slate-950 hero-gradient">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MMWNVNNP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="glass sticky top-0 z-50 w-full px-6 py-4">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
          <div class="font-bold text-2xl tracking-tight flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          Ads <span class="text-blue-600 italic">Calculator</span>
        </div>
        <nav class="flex gap-3 md:gap-6 items-center">
          <a href="/blog" title="Visit Ads Calculator Blog" class="text-sm font-medium text-gray-600 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white transition-colors">
            Blog
          </a>
          <div class="flex items-center gap-2 text-sm font-medium border-l border-gray-200 dark:border-gray-800 pl-3 md:pl-6">
            <a href="/" title="English version" class="px-2 py-1 rounded-md transition-all bg-blue-600 text-white shadow-lg shadow-blue-600/25">EN</a>
            <a href="/es" title="Versión en español" class="px-2 py-1 rounded-md transition-all text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">ES</a>
            <a href="/ca" title="Versió en català" class="px-2 py-1 rounded-md transition-all text-gray-500 hover:text-gray-800 dark:hover:text-gray-200">CA</a>
          </div>
        </nav>
      </div>
    </header>

    <main class="flex-grow">
      <!-- HERO SECTION -->
      <section class="pt-16 sm:pt-20 pb-12 px-4 sm:px-6">
        <div class="max-w-4xl mx-auto text-center space-y-6 sm:space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-1000">
          <span class="inline-block px-4 py-1.5 bg-blue-600/10 text-blue-600 rounded-full text-sm font-semibold tracking-wide uppercase">
            Free Tool
          </span>
          <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold tracking-tight text-slate-900 dark:text-white leading-[1.1]">
            {t.heroTitle}
          </h1>
          <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto leading-relaxed">
            {t.heroSubtitle}
          </p>
          <div class="flex justify-center pt-4">
            <a href="#calculator" title="Go directly to ROAS and ROI calculator" class="px-8 py-4 bg-blue-600 text-white rounded-2xl font-bold text-lg shadow-2xl shadow-blue-600/30 hover:scale-105 active:scale-95 transition-all flex items-center gap-2 group">
              {t.cta}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <!-- FEATURES PREVIEW -->
      <section class="py-12 px-6">
        <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
          {t.features.map(f => (
            <div class="p-6 rounded-3xl bg-white/50 dark:bg-white/5 border border-white dark:border-white/10 shadow-sm">
              <h3 class="font-bold text-lg mb-2">{f.title}</h3>
              <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- CALCULATOR SECTION -->
      <section id="calculator" class="py-12 sm:py-20 px-2 sm:px-6 scroll-mt-24">
        <div class="max-w-6xl mx-auto">
          <div class="bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl rounded-[2rem] sm:rounded-[2.5rem] shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden ring-1 ring-black/5">
             <Calculator client:load lang={lang} />
          </div>
        </div>
      </section>

      <!-- SEO CONTENT -->
      <section class="py-16 px-6">
        <div class="max-w-4xl mx-auto prose dark:prose-invert prose-blue prose-headings:font-bold prose-h2:text-3xl prose-h3:text-xl">
          <h2>Why calculating your Ads profitability is crucial?</h2>
          <p>
            Running digital advertising campaigns without tracking your actual profit is a fast track to burning your budget. In performance and growth marketing, knowing your exact margins, your breakeven point, and your real Return on Investment (ROI) is non-negotiable. 
            This <strong class="font-semibold text-blue-600 dark:text-blue-400">profit ads calculator</strong> helps you move beyond vanity metrics and understand exactly how much money your business is making after all costs are deducted.
          </p>

          <h3>What is ROAS and how is it calculated?</h3>
          <p>
            <strong>ROAS</strong> (Return on Ad Spend) measures the gross revenue generated for every dollar spent on advertising. It's the most common metric used inside ad platforms like Facebook Ads or Google Ads. 
          </p>
          <p>
            The formula is simple: <code>ROAS = Total Revenue / Ad Spend</code>. 
            While a 3x or 4x ROAS might sound great, it only tells half the story. ROAS does not account for product costs, shipping, or taxes, which is why relying solely on it can be dangerous for ecommerce and SaaS businesses.
          </p>

          <h3>Understanding real ROI (including COGS and VAT)</h3>
          <p>
            Unlike ROAS, <strong>ROI</strong> (Return on Investment) gives you a complete picture of your profitability. To calculate your real <em>marketing ROI</em>, you must subtract the <strong>COGS</strong> (Cost of Goods Sold) and taxes (like VAT or sales tax) from your revenue.
          </p>
          <p>
            A high ROAS can actually mask a negative ROI if your product costs and taxes are too high. Our <strong class="font-semibold text-blue-600 dark:text-blue-400">free ROAS calculator</strong> automatically factors in your sale price, unit costs, and tax rate so you can see your true Net Profit and CPA (Cost Per Acquisition).
          </p>

          <h3>What does the Breakeven point mean?</h3>
          <p>
            Your <strong>Breakeven ROAS</strong> is the exact multiplier you need to hit on your ads just to cover all your expenses without losing money. If your actual ROAS is lower than your Breakeven ROAS, your ad campaigns are bleeding money. If it's higher, you are generating pure profit.
          </p>
          <p>
            By knowing your breakeven point, you can confidently scale your winning campaigns and kill the losing ones before they drain your bank account.
          </p>
        </div>
      </section>
    </main>

    <footer class="bg-white/50 dark:bg-slate-900/50 border-t border-gray-200 dark:border-gray-800 py-12 px-6">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="text-center md:text-left">
           <div class="font-bold text-xl mb-2 flex items-center justify-center md:justify-start gap-2">
              <div class="w-6 h-6 bg-blue-600 rounded-md flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
              </div>
              Ads <span class="text-blue-600 italic">Calculator</span>
           </div>
           <p class="text-sm text-slate-500 dark:text-slate-400">© 2026 Ads Calculator. All rights reserved.</p>
           <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Contact: <a href="mailto:info@adsroicalc.com" class="hover:text-blue-600 transition-colors">info@adsroicalc.com</a></p>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-sm font-medium text-slate-600 dark:text-slate-400">
           <a href="/blog" title="See all blog posts" class="hover:text-blue-600 transition-colors">Blog</a>
           <a href="/privacy" title="Privacy Policy" class="hover:text-blue-600 transition-colors">Privacy</a>
           <a href="/legal" title="Legal Notice" class="hover:text-blue-600 transition-colors">Legal</a>
           <a href="/cookies" title="Cookie Policy" class="hover:text-blue-600 transition-colors">Cookies</a>
        </div>
      </div>
    </footer>
  </body>
</html>
